{
  "name": "black-maple-ink",
  "version": "1.0.0",
  "description": "Black Maple Ink — production multi-location tattoo studio website with consultation booking and Paystack deposits",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "db:seed": "node server/db.js --seed",
    "health": "node -e \"fetch('http://localhost:'+(process.env.PORT||3000)+'/api/health').then(r=>r.json()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tattoo",
    "booking",
    "paystack",
    "multisite"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "uuid": "^11.0.5"
  }
}
