# Server
NODE_ENV=production
PORT=3000
SITE_URL=https://blackmapleink.ca
CORS_ORIGIN=https://blackmapleink.ca

# Deposit (amount in the smallest currency unit — e.g. kobo, cents)
# Paystack common currencies: NGN, GHS, ZAR, USD, KES
DEPOSIT_AMOUNT=5000
DEPOSIT_CURRENCY=NGN
DEPOSIT_LABEL=₦50.00

# Paystack — https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: same secret used to verify webhooks (defaults to PAYSTACK_SECRET_KEY)
PAYSTACK_WEBHOOK_SECRET=

# Admin dashboard (change in production)
ADMIN_API_KEY=change-me-to-a-long-random-string

# Studio contact (shown in emails / config)
STUDIO_EMAIL=hello@blackmapleink.ca
STUDIO_PHONE=+1-416-555-0199
